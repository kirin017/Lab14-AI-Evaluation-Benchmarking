# API Keys cho Multi-Judge Consensus Engine
# Copy file này thành .env và điền key thật

# OpenAI (bắt buộc cho Judge 1 và Arbitrator)
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini (bắt buộc cho Judge 2)
# Hoặc dùng GOOGLE_API_KEY nếu bạn thích
GEMINI_API_KEY=your-gemini-key-here

# Optional: Anthropic (nếu muốn thêm judge Claude sau này)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Force mock mode (để test không tốn token)
# MOCK_JUDGE=1